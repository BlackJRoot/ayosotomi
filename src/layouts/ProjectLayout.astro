---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../lib/utils';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<BaseLayout
  title={`${project.data.title} — Ayomiposi Sotomi`}
  description={project.data.description}
>
  <article class="mx-auto max-w-2xl px-6 py-20">
    <header>
      <h1 class="font-serif text-4xl font-medium text-text md:text-5xl">
        {project.data.title}
      </h1>
      <p class="mt-4 text-text-secondary">{project.data.description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-text-secondary">
        <span>Started {formatDate(project.data.startedAt)}</span>
        {
          project.data.githubUrl && (
            <a
              href={project.data.githubUrl}
              class="text-link transition-colors duration-300 hover:text-accent"
            >
              GitHub
            </a>
          )
        }
        {
          project.data.demoUrl && (
            <a
              href={project.data.demoUrl}
              class="text-link transition-colors duration-300 hover:text-accent"
            >
              Live demo
            </a>
          )
        }
      </div>
    </header>

    <div class="prose prose-neutral mt-10 max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
