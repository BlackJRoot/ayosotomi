---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;

const statusStyles: Record<CollectionEntry<'projects'>['data']['status'], string> = {
  active: 'bg-green-100 text-green-800',
  learning: 'bg-blue-100 text-blue-800',
  completed: 'bg-gray-100 text-gray-700',
  archived: 'bg-gray-100 text-gray-500',
};
---

<div class="group relative isolate">
  <div
    aria-hidden="true"
    class="absolute inset-0 z-0 rotate-[-3deg] translate-y-[3px] rounded-xl border border-border bg-bg transition-transform duration-300 group-hover:rotate-[-6deg] group-hover:translate-y-[6px]"
  >
  </div>
  <div
    aria-hidden="true"
    class="absolute inset-0 z-[1] rotate-[2deg] translate-y-[2px] rounded-xl border border-border bg-code-bg transition-transform duration-300 group-hover:rotate-[4deg] group-hover:translate-y-[4px]"
  >
  </div>

  <a
    href={`/projects/${project.id}/`}
    class="relative z-10 block rounded-xl border border-border bg-bg p-4 transition-all duration-300 group-hover:-translate-y-0.5 group-hover:border-accent active:scale-[0.98]"
  >
    <div class="flex items-center justify-between gap-4">
      <h3
        class="font-serif text-xl text-text transition-colors duration-300 group-hover:text-accent"
      >
        {project.data.title}
      </h3>
      <span
        class={`shrink-0 rounded-full px-2 py-0.5 text-xs font-medium capitalize ${statusStyles[project.data.status]}`}
      >
        {project.data.status}
      </span>
    </div>
    <p class="mt-2 text-text-secondary">{project.data.description}</p>
    <ul class="mt-3 flex flex-wrap gap-2">
      {
        project.data.tech.map((tech) => (
          <li class="rounded-full border border-border px-2 py-0.5 text-xs text-text-secondary">
            {tech}
          </li>
        ))
      }
    </ul>
  </a>
</div>
