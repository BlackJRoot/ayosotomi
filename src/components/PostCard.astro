---
import type { CollectionEntry } from 'astro:content';
import { formatDate, calculateReadingTime } from '../lib/utils';
import ReadingTime from './ReadingTime.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  showBullet?: boolean;
}

const { post, showBullet = false } = Astro.props;
const readingTime = calculateReadingTime(post.body ?? '');
---

<article>
  <a href={`/writing/${post.id}/`} class="post-link group flex gap-3">
    {showBullet && <span class="bullet mt-2 h-1.5 w-1.5 shrink-0 rounded-full border border-accent" />}
    <span class="min-w-0">
      <h3
        class="font-serif text-xl text-text transition-colors duration-300 group-hover:text-accent"
      >
        {post.data.title}
      </h3>
      <p class="mt-2 text-text-secondary">{post.data.description}</p>
      <p class="mt-2 text-sm text-text-secondary">
        {formatDate(post.data.publishedAt)} · <ReadingTime minutes={readingTime} />
      </p>
    </span>
  </a>
</article>

<style>
  .post-link:visited .bullet {
    border-color: var(--color-visited);
    background-color: var(--color-visited);
  }
</style>
