---
import ThemeToggle from './ThemeToggle.astro';
---

<header
  class="mx-auto flex w-full max-w-2xl flex-wrap items-center justify-between gap-x-4 gap-y-3 px-6 py-8 transition-colors duration-300"
>
  <a
    href="/"
    class="order-1 font-serif text-xl text-text hover:text-accent transition-colors duration-300"
  >
    Ayomiposi Sotomi
  </a>
  <ThemeToggle class="order-2 sm:order-3" />
  <nav
    class="order-3 flex w-full gap-6 text-sm text-text-secondary sm:order-2 sm:w-auto"
  >
    <a href="/writing" class="hover:text-accent transition-colors duration-300">
      Writing
    </a>
    <a href="/projects" class="hover:text-accent transition-colors duration-300">
      Projects
    </a>
    <a href="/now" class="hover:text-accent transition-colors duration-300">
      Now
    </a>
    <a href="/about" class="hover:text-accent transition-colors duration-300">
      About
    </a>
  </nav>
</header>
