---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// Now: latest entry, used for the "Currently" pulse under the hero.
const nowEntries = await getCollection('now');
const currentNow = nowEntries.sort(
  (a, b) => b.data.updatedAt.valueOf() - a.data.updatedAt.valueOf()
)[0];

// First non-placeholder item from a list ("—" prefixes mark a placeholder).
function firstReal(items?: string[]): string | undefined {
  return items?.find((s) => s && !s.trim().startsWith('—'));
}

const pulseParts: string[] = [];
if (currentNow) {
  const w = firstReal(currentNow.data.workingOn);
  const l = firstReal(currentNow.data.learning);
  const r = firstReal(currentNow.data.reading);
  if (w) pulseParts.push(w);
  if (l) pulseParts.push(`learning ${l}`);
  if (r) pulseParts.push(`reading ${r}`);
}

// Writing: newest essay leads the featured slot; fall back to newest post of any kind.
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const featured = posts.find((p) => p.data.category === 'essay') ?? posts[0];

// Optional cover thumbnail: src/assets/covers/<post-slug>.<ext>, optimized via <Image>.
// No cover for a post → the featured block simply renders without one.
const covers = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/covers/*.{jpeg,jpg,png,webp}',
  { eager: true }
);
const featuredSlug = featured?.id.split('/').pop();
const coverImage = featuredSlug
  ? Object.entries(covers).find(
      ([path]) => path.split('/').pop()?.replace(/\.[^.]+$/, '') === featuredSlug
    )?.[1].default
  : undefined;

const beds = [
  { href: '/writing', title: 'Writing', note: `${posts.length} essays & notes` },
  { href: '/projects', title: 'Projects', note: 'homelab & builds' },
  { href: '/now', title: 'Now', note: 'a living page' },
];
---

<BaseLayout
  title="Ayomiposi Sotomi"
  description="Writer. Builder. Security-minded human."
>
  <div class="relative mx-auto max-w-2xl px-6 py-16">
    <svg
      aria-hidden="true"
      viewBox="0 0 80 120"
      class="pointer-events-none absolute right-6 top-14 hidden w-14 text-accent opacity-40 sm:block"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
    >
      <path d="M40 118 C40 90 40 60 40 20" />
      <path d="M40 70 C24 64 18 50 20 38 C34 40 42 54 40 70Z" />
      <path d="M40 54 C56 48 62 34 60 22 C46 24 38 38 40 54Z" />
      <path d="M40 90 C26 86 20 74 22 64 C34 66 42 78 40 90Z" />
    </svg>

    <section>
      <h1
        class="max-w-[22ch] font-serif text-3xl font-normal leading-snug text-text sm:text-4xl"
      >
        <span class="text-text-secondary">Hi, I'm</span> Ayomiposi
        <span class="text-text-secondary">—</span> a writer, builder, and security-minded
        human.
      </h1>

      {
        pulseParts.length > 0 && (
          <p class="mt-5 flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <span class="font-mono text-[10.5px] uppercase tracking-widest text-accent">
              Currently
            </span>
            <span class="text-text-secondary">{pulseParts.join(' · ')}</span>
          </p>
        )
      }
    </section>

    <section class="mt-10 grid grid-cols-1 gap-3.5 sm:grid-cols-3">
      {
        beds.map((bed) => (
          <a
            href={bed.href}
            class="group block rounded-xl border border-border p-4 transition-colors duration-300 hover:border-accent"
          >
            <span class="block font-serif text-lg text-text transition-colors duration-300 group-hover:text-accent">
              {bed.title}
            </span>
            <span class="mt-1 block text-sm text-text-secondary">{bed.note}</span>
          </a>
        ))
      }
    </section>

    {
      featured && (
        <section class="mt-8 flex gap-5">
          {coverImage && (
            <a href={`/writing/${featured.id}/`} class="shrink-0">
              <Image
                src={coverImage}
                alt={`Cover image for ${featured.data.title}`}
                width={208}
                height={256}
                class="h-32 w-[104px] rounded-lg border border-border object-cover"
              />
            </a>
          )}
          <div class="border-l-[3px] border-accent pl-5">
            <p class="font-mono text-[11px] uppercase tracking-widest text-text-secondary">
              Latest essay
            </p>
            <a href={`/writing/${featured.id}/`} class="group block">
              <h2 class="mt-1.5 font-serif text-xl text-text transition-colors duration-300 group-hover:text-accent">
                {featured.data.title}
              </h2>
            </a>
            <p class="mt-2 font-serif text-[15px] italic text-text-secondary">
              {featured.data.description}
            </p>
            <a
              href={`/writing/${featured.id}/`}
              class="mt-2 inline-block text-sm text-link transition-colors duration-300 hover:text-accent"
            >
              Read the essay →
            </a>
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
