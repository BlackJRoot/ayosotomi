---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — Ayomiposi Sotomi"
  description="This page doesn't exist."
>
  <div class="mx-auto max-w-2xl px-6 py-20 text-center">
    <p class="text-sm uppercase tracking-wider text-text-secondary">404</p>
    <h1 class="mt-2 font-serif text-4xl font-medium text-text md:text-5xl">
      There's nothing here.
    </h1>
    <p class="mt-4 text-lg text-text-secondary">
      The page you're looking for doesn't exist, or moved.
    </p>
    <a
      href="/"
      class="mt-8 inline-block text-link transition-colors duration-300 hover:text-accent"
    >
      ← Back home
    </a>
  </div>
</BaseLayout>
